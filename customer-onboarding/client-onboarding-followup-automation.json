        "jsCode": "let count = 1;\nlet key = 2;\nlet groupedData = {}\nlet alltemplateStatusData = {\n  1: true,\n  2: false,\n  3: false,\n  4: false,\n  5: false,\n  6: false,\n  7: false,\n  8: false,\n  9: false,\n}\nlet lastStepData = null;\nfor (const element of $input.all()) {\n  if(count == 1){\n    count +=1;\n    console.log(\"in continue\")\n  }else{\n    console.log(count)\n    if(!(key in groupedData)){\n      groupedData[`${key}`] = [];\n    }\n    console.log(\"after continue\")\n    count +=1;\n    console.log({key, groupedData, \"col_7\": element.json[\"col_7\"]})\n    groupedData[`${key}`].push(element.json)\n    if(element.json['col_6'] == \"\" && element.json['col_6']?.toLowerCase() != \"x\"){\n      console.log(\"in break statement\")\n      lastStepData = element.json;\n      break;\n    }\n  }\n}\nreturn {lastStepData: lastStepData};"
