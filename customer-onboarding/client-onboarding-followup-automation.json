      "parameters": {
        "sendTo": "={{ \n  [\n    $('Get row(s)').item.json.client_email, \n    $('Get row(s)').item.json.team_emails, \n    \n  ]\n  .filter(email => email && email.trim() !== '')\n  .join(',') \n}}",
        "subject": "Caddy Onboarding – Urgent: Task Now 15 Days Overdue",
        "message": "=<!DOCTYPE html>\n<html>\n  <head>\n    <title>Hello, World!</title>\n    <link rel=\"stylesheet\" href=\"styles.css\" />\n  </head>\n  <body>\n    <div dir=\"ltr\">\n      <div>\n        Hi Team&nbsp;{{ $('Get row(s)').first().json.client_name }},\n      </div>\n      <div><br /></div>\n      <div>\n        We’re now at <strong>15 days overdue</strong> for the following\n        task:&nbsp;{{ $('Code in JavaScript1').first().json.lastStepData.col_2 }}\n      </div>\n      <div>\n        <p>\n          At this stage, it’s important we address any blockers so we can get your\n          onboarding timeline back on track.\n        </p>\n        <p>\n          To help move this forward, I’d like to propose a\n          <strong>short working session (15 minutes)</strong>. Whether you need\n          clarification, help completing the task, or simply a focused timeblock to\n          get it done, I’m happy to walk through it with you.\n        </p>\n        <p>\n          Gabrielle will follow up with a few available 15-minute time slots from my\n          calendar.<br />\n          Please choose the one that works best for you, and we’ll get it booked.\n        </p>\n        <p>\n          If the task has already been completed, kindly update your&nbsp;<a\n            href=\"https://drive.google.com/file/d/{{ $('HTTP Request').first().json.id }}/view?usp=sharing\"\n            target=\"_blank\"\n            >Implementation Checklist</a\n          >&nbsp;by marking an \"X\" in Column F.\n        </p>\n        <p>Looking forward to helping you get this across the finish line.</p>\n        <p>\n          Best regards,<br />\n          Ron\n        </p>\n      </div>\n      <font color=\"#888888\"\n        ><span class=\"gmail_signature_prefix\">-- </span><br />\n        <div dir=\"ltr\" class=\"gmail_signature\" data-smartmail=\"gmail_signature\">\n          <div dir=\"ltr\">\n            <div>\n              <font color=\"#000000\"><strong>Ron&nbsp;Leung</strong><br /></font>\n            </div>\n            <div><font color=\"#000000\">Chief Executive Officer, Caddy</font></div>\n            <div>\n              <span style=\"line-height: 17.6px\"\n                ><font color=\"#000000\">C:&nbsp;+1.416.305.6148</font></span\n              >\n            </div>\n            <div>\n              <span style=\"line-height: 17.6px\"\n                ><font color=\"#000000\"\n                  ><a\n                    href=\"\"\n                    target=\"_blank\"\n                    >See Caddy in Action</a\n                  ></font\n                ></span\n              >\n            </div>\n            <div>\n              <span style=\"line-height: 17.6px\"\n                ><font color=\"#000000\"><br /></font\n              ></span>\n            </div>\n            <div>\n              <div>\n                <span style=\"line-height: 17.6px\"\n                  ><strong\n                    ><font color=\"#000000\"\n                      ><img\n                        src=\"https://ci3.googleusercontent.com/mail-sig/AIorK4ycCGHasYDe59VAZsP7OmlK3AYe8ED6f2w57rBEEzSZsOhL3z0RQ5pn9l02HEJX6z2PhbbZ1rU\"\n                        width=\"200\"\n                        height=\"47\"\n                        class=\"CToWUd\"\n                        data-bit=\"iit\" /><br /></font></strong\n                ></span>\n              </div>\n              <div>\n                <span style=\"line-height: 17.6px\"\n                  ><strong\n                    ><font color=\"#000000\"><br /></font></strong\n                ></span>\n              </div>\n              <div>\n                <span style=\"line-height: 17.6px\"\n                  ><b style=\"color: rgb(255, 0, 0)\">Core Support Hours:</b\n                  ><span style=\"color: rgb(255, 0, 0)\"\n                    >&nbsp;Mon-Fri, 9:00 AM ET to 6:00 PM ET (Responses may be\n                    delayed outside these hours)</span\n                  ><strong><font color=\"#000000\"></font></strong\n                ></span>\n              </div>\n              <div>\n                <span style=\"color: rgb(0, 0, 0)\"\n                  ><span style=\"font-size: 14.6667px; line-height: 17.6px\"\n                    ><span style=\"color: rgb(80, 0, 80)\"\n                      ><strong><br /></strong></span></span\n                ></span>\n              </div>\n            </div>\n          </div>\n        </div>\n        <img\n          src=\"https://ci3.googleusercontent.com/meips/ADKq_NbKOEVDNuh-i3ZM2gtJ1v3X9-vgi_h2ESnPoCGgnsBs8VmoZHnvwCVYswjCY9JwwqKcsAUIXtqdhJuTEnJw77OQjlcavyW-wb0wPj-Mb-5IAxPU8mNkkj_gZkb43IoQfmzsb_2fOYkbAewkkJNjRbd5WHAS0qHqc-YNtMqSZkzBOdcqvyYwbNlWYXhPHKx7uqd0Qskz4i6sydGTQwg8FsbFQE6XPXiwJeSEy0ABWsg_w-GXm8zK=s0-d-e1-ft#https://d13r5V04.na1.hs-sales-engage.com/Cto/5E+23284/d13r5V04/R5R8b41MGN65yjsy2fDrvW3GHNGF3z7rSgW1--7rr1X0FjCW1Gd3d13GGshqW23f3gv23fthFW3DMBb91S573Sn1S1nZM4W1\"\n          alt=\"\"\n          height=\"1\"\n          width=\"1\"\n          style=\"display: none !important\"\n          class=\"CToWUd\"\n          data-bit=\"iit\" />\n        <div></div>\n        <div\n          id=\"m_1717891694854804735data-hbsasc-v0-9d0caec7-f976-4309-87f5-34cd55491e75\"\n        ></div\n      ></font>\n    </div>\n  </body>\n</html>",
